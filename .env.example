# ─────────────────────────────────────────────────────────────
# KonquerAI Landing — Variables de entorno
# Copia este archivo a `.env` y rellena cada valor.
# `.env` NO se versiona (está en .gitignore). En Vercel, añade
# las mismas variables en Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Formulario de contacto (Web3Forms) — YA EN USO ──
# 1. Entra en https://web3forms.com con info@konquerai.com
# 2. Copia la "Access Key" que te envían a ese correo.
# Pública (se usa en el cliente). Los envíos llegan al email de la Access Key.
PUBLIC_WEB3FORMS_ACCESS_KEY=

# ── Chatbot "Tu consultor de Obra" ──

# LLM vía OpenRouter (https://openrouter.ai/keys). SECRETA, solo en /api.
# Empieza por sk-or-...  | Modelo configurable por string.
OPENROUTER_API_KEY=
# Modelo a usar (opcional). Por defecto: anthropic/claude-3.5-haiku
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Transcripción de voz, Groq Whisper Large V3 (https://console.groq.com/keys).
# SECRETA, solo en /api. Empieza por gsk_...
GROQ_API_KEY=

# Supabase (proyecto NUEVO: konker-landing-crm). Project Settings → API.
# SUPABASE_URL es pública; SERVICE_ROLE_KEY es SECRETA (solo en /api).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cal.com — URL del evento para agendar la llamada (p. ej. konker/llamada).
# Pública (se embebe en el cliente).
PUBLIC_CALCOM_URL=
