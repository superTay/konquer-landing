<svg width="320" height="640" xmlns="http://www.w3.org/2000/svg">
  <rect width="320" height="640" fill="#F6F8F9"/>
  <rect x="20" y="20" width="280" height="60" rx="8" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="160" y="55" text-anchor="middle" font-family="system-ui" font-size="14" font-weight="600" fill="#0B1F24">KonquerAI</text>
  <rect x="20" y="100" width="280" height="120" rx="8" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="160" y="140" text-anchor="middle" font-family="system-ui" font-size="12" fill="#4B5563">Presupuesto</text>
  <text x="160" y="165" text-anchor="middle" font-family="system-ui" font-size="18" font-weight="700" fill="#00D1B2">4.500,00 €</text>
  <text x="160" y="195" text-anchor="middle" font-family="system-ui" font-size="10" fill="#4B5563">Pintura 3 hab. con gotelé</text>
  <rect x="20" y="240" width="280" height="40" rx="8" fill="#00D1B2"/>
  <text x="160" y="265" text-anchor="middle" font-family="system-ui" font-size="13" font-weight="600" fill="#FFFFFF">Enviar al cliente</text>
  <rect x="20" y="300" width="280" height="200" rx="8" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="40" y="330" font-family="system-ui" font-size="11" fill="#4B5563">Partida 1 — Mano de obra</text>
  <text x="260" y="330" text-anchor="end" font-family="system-ui" font-size="11" font-weight="600" fill="#0B1F24">2.100 €</text>
  <line x1="40" y1="345" x2="280" y2="345" stroke="#E5EAEC"/>
  <text x="40" y="370" font-family="system-ui" font-size="11" fill="#4B5563">Partida 2 — Material</text>
  <text x="260" y="370" text-anchor="end" font-family="system-ui" font-size="11" font-weight="600" fill="#0B1F24">1.400 €</text>
  <line x1="40" y1="385" x2="280" y2="385" stroke="#E5EAEC"/>
  <text x="40" y="410" font-family="system-ui" font-size="11" fill="#4B5563">Partida 3 — Desplazamiento</text>
  <text x="260" y="410" text-anchor="end" font-family="system-ui" font-size="11" font-weight="600" fill="#0B1F24">200 €</text>
  <rect x="20" y="520" width="280" height="100" rx="8" fill="#E6FAF6" stroke="#00D1B2" stroke-dasharray="4"/>
  <text x="160" y="565" text-anchor="middle" font-family="system-ui" font-size="11" fill="#00D1B2" font-weight="600">PLACEHOLDER</text>
  <text x="160" y="585" text-anchor="middle" font-family="system-ui" font-size="9" fill="#4B5563">Captura real próximamente</text>
</svg>
