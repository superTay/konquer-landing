  <text x="295" y="48" text-anchor="middle" font-family="system-ui" font-size="9" fill="#4B5563">Cobrado mes</text>
  <text x="295" y="75" text-anchor="middle" font-family="system-ui" font-size="18" font-weight="700" fill="#0B1F24">18.200 €</text>
  <rect x="20" y="120" width="170" height="80" rx="8" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="105" y="148" text-anchor="middle" font-family="system-ui" font-size="9" fill="#4B5563">Pipeline activo</text>
