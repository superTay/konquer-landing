<svg width="400" height="280" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="280" fill="#F6F8F9"/>
  <!-- Chat bubbles -->
  <rect x="100" y="20" width="280" height="40" rx="12" fill="#00D1B2"/>
  <text x="240" y="45" text-anchor="middle" font-family="system-ui" font-size="11" fill="#FFFFFF">Hazme un presupuesto para pintar 3 hab. con gotelé</text>
  <rect x="20" y="75" width="280" height="80" rx="12" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="30" y="95" font-family="system-ui" font-size="10" fill="#4B5563">Presupuesto generado:</text>
  <text x="30" y="115" font-family="system-ui" font-size="11" font-weight="600" fill="#0B1F24">Pintura 3 habitaciones con gotelé</text>
  <text x="30" y="135" font-family="system-ui" font-size="10" fill="#4B5563">Total: 4.500 € (IVA incl.)</text>
  <text x="30" y="148" font-family="system-ui" font-size="9" fill="#00D1B2">Listo para enviar</text>
  <rect x="100" y="170" width="280" height="30" rx="12" fill="#00D1B2"/>
  <text x="240" y="190" text-anchor="middle" font-family="system-ui" font-size="11" fill="#FFFFFF">Envíalo al cliente</text>
  <rect x="20" y="215" width="200" height="30" rx="12" fill="#FFFFFF" stroke="#E5EAEC"/>
  <text x="120" y="235" text-anchor="middle" font-family="system-ui" font-size="10" fill="#00D1B2">Enviado a cliente@email.com</text>
  <rect x="40" y="255" width="320" height="15" rx="4" fill="#E6FAF6" stroke="#00D1B2" stroke-dasharray="4"/>
  <text x="200" y="266" text-anchor="middle" font-family="system-ui" font-size="8" fill="#00D1B2" font-weight="600">PLACEHOLDER</text>
</svg>
