---
/**
 * Hero.astro — Versión A de 06_homepage_copy.md (Recomendada para arranque)
 * Copy LITERAL. No se modifica.
 */
import { Image } from "astro:assets";
import heroBalance from "../assets/screenshots/hero-balance.png";
---

<section class="hero" id="hero">
  <div class="hero-aurora" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>
  <div class="hero-inner container-narrow">
    <div class="hero-content">
      <p class="text-eyebrow hero-eyebrow">App de gestión para autónomos de reformas</p>

      <h1 class="hero-h1">Tu cuadrilla administrativa, ahora digital.</h1>

      <p class="hero-sub">
        Recupera hasta 30 horas al mes y controla cada obra al céntimo.<br />
        Sin Excel. Sin gestoría sufriendo cada trimestre. Sin aprender tecnología.
      </p>

      <div class="hero-actions">
        <button type="button" class="btn btn-primary hero-cta-primary" data-open-lucia>
          Echa cuentas con LucIA — gratis
        </button>
        <a href="#como-funciona" class="btn-ghost hero-cta-secondary">
          Ver cómo funciona <span aria-hidden="true">→</span>
        </a>
      </div>

      <p class="hero-trust">
        Listo en 15 minutos · Garantía de 30 días · Sin permanencia
      </p>
    </div>

    <div class="hero-visual">
      <Image
        src={heroBalance}
        alt="La app de KonquerAI en el móvil: balance del mes, pendiente de cobro y el IVA del trimestre de un vistazo"
        width={520}
        densities={[1, 2]}
        loading="eager"
        fetchpriority="high"
        class="hero-mockup"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100dvh - 72px);
    display: flex;
    align-items: center;
    padding-block: 3rem 4rem;
    overflow: hidden;
  }

  .hero-aurora {
    position: absolute;
    inset: -25% -10% auto -10%;
    height: 160%;
    z-index: 0;
    background:
      radial-gradient(38% 48% at 16% 26%, rgba(0, 209, 178, 0.24), transparent 70%),
      radial-gradient(34% 44% at 84% 16%, rgba(255, 138, 0, 0.15), transparent 70%),
      radial-gradient(42% 52% at 74% 84%, rgba(0, 209, 178, 0.15), transparent 70%),
      radial-gradient(30% 38% at 48% 54%, rgba(0, 209, 178, 0.07), transparent 75%);
    filter: blur(26px);
    animation: aurora 22s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes aurora {
    0%   { transform: translate3d(0, 0, 0) scale(1); }
    100% { transform: translate3d(-2%, -3%, 0) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 0.8fr;
      gap: 4rem;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Entrada coreografiada al cargar (above-the-fold = wow inmediato) ── */
  @keyframes heroEnter {
    from { opacity: 0; transform: translateY(28px); }
  }
  @keyframes heroEnterH1 {
    from { opacity: 0; transform: translateY(40px); filter: blur(10px); }
  }
  @keyframes heroEnterVisual {
    from { opacity: 0; transform: translateY(44px) scale(0.93); filter: blur(8px); }
  }

  .hero-content > * {
    animation: heroEnter 0.8s var(--ease-out-expo) backwards;
  }
  .hero-eyebrow { animation-delay: 0.05s; }
  .hero-h1 {
    animation: heroEnterH1 0.95s var(--ease-out-expo) backwards;
    animation-delay: 0.15s;
  }
  .hero-sub     { animation-delay: 0.30s; }
  .hero-actions { animation-delay: 0.42s; }
  .hero-trust   { animation-delay: 0.52s; }

  .hero-eyebrow {
    color: var(--color-teal);
  }

  .hero-h1 {
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    line-height: 1.08;
    max-width: 640px;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-slate);
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .hero-cta-primary {
    font-size: 1.0625rem;
    padding: 1rem 2.5rem;
  }

  .hero-cta-secondary {
    font-size: 0.9375rem;
    color: var(--color-slate);
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .hero-cta-secondary:hover {
    color: var(--color-teal);
  }

  .hero-trust {
    font-size: 0.8125rem;
    color: var(--color-slate);
    letter-spacing: 0.01em;
    padding-top: 0.25rem;
  }

  /* ── Visual / Mockup de móvil ── */
  .hero-visual {
    display: flex;
    justify-content: center;
    animation: heroEnterVisual 1s var(--ease-out-expo) backwards;
    animation-delay: 0.35s;
  }

  .hero-mockup {
    width: 300px;
    max-width: 100%;
    height: auto;
    border-radius: 30px;
    box-shadow: 0 24px 70px rgba(11, 31, 36, 0.18);
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-aurora,
    .hero-mockup,
    .hero-content > *,
    .hero-h1,
    .hero-visual {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      padding-block: 2rem 3rem;
    }

    .hero-mockup {
      width: 240px;
    }

    .hero-cta-primary {
      width: 100%;
    }
  }
</style>
