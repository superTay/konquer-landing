---
/** Footer.astro — 4 columnas. Copy literal de 06. */
import Logo from "./Logo.astro";
---
<footer class="footer" id="footer">
  <div class="container-narrow footer-inner">
    <div class="footer-col footer-brand">
      <Logo height={64} />
      <p class="footer-tagline">Tu cuadrilla administrativa, ahora digital.</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Producto</h4>
      <ul class="footer-links">
        <li><a href="#como-funciona">Cómo funciona</a></li>
        <li><a href="#pricing">Precios</a></li>
        <li><a href="#para-quien">Para quién es</a></li>
        <li><a href="#demo">App móvil</a></li>
        <li><a href="#faq">Verifactu</a></li>
        <li><a href="https://app.konquerai.com" rel="noopener">Acceder a la app</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Empresa</h4>
      <ul class="footer-links">
        <li><a href="#sobre-nosotros">Sobre nosotros</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/newsletter">Boletín</a></li>
        <li><a href="/#contacto">Contacto</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Legal</h4>
      <ul class="footer-links">
        <li><a href="/legal/terminos">Términos y condiciones</a></li>
        <li><a href="/legal/privacidad">Política de privacidad</a></li>
        <li><a href="/legal/cookies">Política de cookies</a></li>
        <li><a href="/legal/gdpr">Cumplimiento GDPR</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom container-narrow">
    <p>&copy; 2026 KonquerAI · Hecho en España, para autónomos de España.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: rgba(255,255,255,0.7);
    padding-top: 4rem;
    padding-bottom: 2rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer-inner { grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 3rem; }
  }
  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-tagline { font-size: 0.875rem; }
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--color-teal); }
  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.8125rem;
    text-align: center;
  }
</style>
