---
/** CtaFinal.astro — Banda CTA final (punto 1).
 *  El CTA principal abre a LucIA (consultoría = lead magnet), reutilizando el widget
 *  global del chatbot (vive en Base.astro). El secundario lleva a contacto por email.
 *  La estrategia completa de CTAs + lead magnet se afina en el punto 11. */
import { Image } from "astro:assets";
import recuperaDomingo from "../assets/recupera-domingo.png";
---
<section class="cta-final reveal" id="contacto">
  <Image
    src={recuperaDomingo}
    alt=""
    aria-hidden="true"
    width={1600}
    densities={[1, 2]}
    loading="lazy"
    class="cta-bg"
  />
  <div class="grain cta-grain" aria-hidden="true"></div>
  <div class="container-narrow cta-inner">
    <div class="cta-card">
      <h2 class="cta-h2">Recupera el domingo.</h2>
      <p class="cta-body">Empieza con tu Oficina IA. Te guiamos paso a paso para dejarlo todo listo y te quitamos el papeleo de encima. Sin permanencia. Garantía de 30 días.</p>

      <p class="cta-lead">¿No tienes claro si esto es para ti? Habla con LucIA. Te hace unas preguntas, mira tus números y te dice claro si te encaja y por dónde empezar. Gratis y en cinco minutos.</p>

      <div class="cta-actions">
        <button type="button" class="btn btn-white cta-primary" data-open-lucia>Habla con LucIA gratis</button>
        <a href="/precios" class="cta-secondary">O empieza ya — desde 97 €/mes <span aria-hidden="true">→</span></a>
      </div>

      <p class="cta-alt">¿Te surge cualquier duda? Escríbenos a <a href="mailto:info@konquerai.com">info@konquerai.com</a> y te contestamos enseguida.</p>
    </div>
  </div>
</section>

<style>
  .cta-final {
    position: relative;
    background: var(--color-teal-dark);
    padding-block: 5rem;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    z-index: 0;
  }
  /* Velo teal: mantiene marca y legibilidad, deja entrever la escena familiar */
  .cta-final::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.18) 0%, transparent 55%),
      linear-gradient(135deg, rgba(0,209,178,0.86) 0%, rgba(0,123,109,0.92) 100%);
    pointer-events: none;
  }
  .cta-grain {
    z-index: 1;
    opacity: 0.07;
  }
  .cta-inner {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
  }
  .cta-card {
    width: 100%;
    max-width: 600px;
    text-align: center;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-xl);
    padding: 3rem 2rem;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      0 24px 48px rgba(0, 0, 0, 0.18);
  }
  .cta-h2 { color: var(--color-white); font-size: clamp(1.75rem, 4vw, 2.75rem); }
  .cta-body { color: rgba(255,255,255,0.9); margin-top: 1rem; font-size: 1.0625rem; line-height: 1.7; }
  .cta-lead { color: rgba(255,255,255,0.92); margin-top: 1.5rem; font-size: 1.0625rem; line-height: 1.7; }

  .cta-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .cta-primary { width: 100%; font-size: 1.0625rem; }
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-white);
    font-size: 0.9375rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .cta-secondary:hover { opacity: 0.8; text-decoration: underline; }

  .cta-alt {
    margin-top: 1.25rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .cta-alt a {
    color: var(--color-white);
    text-decoration: underline;
    font-weight: 600;
  }

  @media (max-width: 540px) {
    .cta-card { padding: 2.25rem 1.25rem; }
  }
</style>
