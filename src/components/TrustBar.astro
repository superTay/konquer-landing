---
/** TrustBar.astro — Bandera de prueba / social proof strip */
---
<section class="trust-bar" id="trust-bar">
  <div class="container-narrow">
    <p class="trust-text">Acompañando a autónomos de reformas en España.</p>
  </div>
</section>

<style>
  .trust-bar {
    padding-block: 2rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-mist);
  }
  .trust-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-slate);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
</style>
