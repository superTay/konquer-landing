---
/** Oferta.astro — Lo que incluye Tu Oficina IA (6 cores + bonus). Copy literal de 06.
 *  Icons: Lucide-style SVG line icons (24px, 2px stroke)
 */

/* Each core gets a semantic Lucide icon */
const cores = [
  {
    title: "Implantación paso a paso",
    body: "Te guiamos para configurar la app, te enseñamos a usarla y te acompañamos las primeras semanas.",
    /* Lucide: Users (onboarding/people) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: "Presupuestos y facturas desde el móvil",
    body: "Le hablas, ella los monta. Cuando el cliente acepta, la factura se crea sola. PDF con tu logo, enviado con un botón.",
    /* Lucide: FileText (document/budget) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><line x1="10" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="13" x2="8" y1="9" y2="9"/></svg>`,
  },
  {
    title: "Facturas de proveedor, ordenadas solas",
    body: "Llegan por correo o las fotografías. La app saca los datos, las clasifica por proveedor y trimestre. Tú apruebas en 5 segundos.",
    /* Lucide: ScanLine (lectura/escaneo) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 12h10"/></svg>`,
  },
  {
    title: "Tus clientes y proveedores, solos",
    body: "Cada factura crea o actualiza la ficha del cliente o proveedor. Su histórico siempre al día, sin que lo toques.",
    /* Lucide: UserPlus (alta automática de fichas) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>`,
  },
  {
    title: "Control de rentabilidad",
    body: "Margen real por obra. Ranking con semáforo. Sabes qué clientes te hacen ganar dinero.",
    /* Lucide: BarChart3 (analytics) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
  },
  {
    title: "Centro financiero",
    body: "Pendiente de cobro, IVA del trimestre, días medios de cobro y tus números nada más abrir. En 3 segundos.",
    /* Lucide: Wallet (finances) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/></svg>`,
  },
  {
    title: "Conciliación documental",
    body: "Empareja albaranes con facturas. Detecta duplicados antes de que pagues dos veces.",
    /* Lucide: FileScan (document matching) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10V7l-5-5H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 14a2 2 0 0 0-2 2"/><path d="M20 14a2 2 0 0 1 2 2"/><path d="M20 22a2 2 0 0 0 2-2"/><path d="M16 22a2 2 0 0 1-2-2"/></svg>`,
  },
  {
    title: "Adaptación a Verifactu",
    body: "Numeración correlativa, IVA correcto, normativa actualizada. Tú no te enteras.",
    /* Lucide: BadgeCheck (compliance/certification) */
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>`,
  },
];

const bonus = [
  "Plantillas de presupuestos por oficio (pintor, electricista, fontanero, albañil, climatización...)",
  "Calculadora rápida de margen antes de aceptar un trabajo.",
  "Formación para cerrar más presupuestos.",
  "Kit de modernización digital con atajos útiles.",
  "Actualizaciones y nuevas funcionalidades incluidas.",
  "Boletín privado del sector reformas.",
];
---
<section class="section-padding" id="oferta">
  <div class="container-narrow">
    <p class="text-eyebrow oferta-eyebrow reveal">Todo incluido</p>
    <h2 class="oferta-h2 reveal">Esto es lo que recibes el primer día.</h2>
    <p class="oferta-sub reveal">No te vendemos solo una app. Te vendemos un sistema completo, montado y acompañado.</p>

    <div class="oferta-grid reveal-stagger">
      {cores.map(c => (
        <div class="oferta-card reveal">
          <div class="oferta-icon" aria-hidden="true">
            <Fragment set:html={c.icon} />
          </div>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>

    <div class="oferta-bonus reveal">
      <div class="bonus-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
        </svg>
        <h3>Y además, sin coste extra:</h3>
      </div>
      <ul>
        {bonus.map(b => (
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
            {b}
          </li>
        ))}
      </ul>
    </div>

    <div class="oferta-cta reveal">
      <a href="/precios" class="btn btn-primary">Empieza ahora</a>
    </div>
  </div>
</section>

<style>
  .oferta-eyebrow {
    text-align: center;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .oferta-h2 { text-align: center; }
  .oferta-sub {
    text-align: center;
    color: var(--color-slate);
    margin-top: 0.75rem;
    margin-bottom: 3rem;
    max-width: 560px;
    margin-inline: auto;
  }
  .oferta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .oferta-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .oferta-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .oferta-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .oferta-card:hover {
    box-shadow: var(--shadow-glow);
    transform: translateY(-6px);
    border-color: rgba(0, 209, 178, 0.6);
  }

  /* ── Icon wrapper ── */
  .oferta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, var(--color-teal-light), #ffffff);
    color: var(--color-teal);
    border: 1px solid rgba(0, 209, 178, 0.18);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    margin-bottom: 1.25rem;
    transition: transform 0.35s var(--ease-spring), background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
  }

  .oferta-icon svg { width: 28px; height: 28px; }

  .oferta-card:hover .oferta-icon {
    background: linear-gradient(150deg, var(--color-teal), var(--color-teal-dark));
    color: var(--color-white);
    transform: translateY(-2px) scale(1.06);
    box-shadow: var(--shadow-glow-soft);
  }

  .oferta-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.0625rem;
    color: var(--color-ink);
  }
  .oferta-card p {
    color: var(--color-slate);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  /* ── Bonus box ── */
  .oferta-bonus {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--color-teal-light);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-teal);
  }
  .bonus-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
    color: var(--color-teal);
  }
  .bonus-header h3 {
    margin: 0;
    color: var(--color-ink);
  }
  .oferta-bonus ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .oferta-bonus ul { grid-template-columns: repeat(2, 1fr); }
  }
  .oferta-bonus li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-slate);
    line-height: 1.5;
  }
  .oferta-bonus li svg {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .oferta-cta {
    margin-top: 2.5rem;
    text-align: center;
  }
</style>
