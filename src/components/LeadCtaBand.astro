---
/** LeadCtaBand.astro — Banda slim de captación (LEAD). Abre a LucIA.
 *  Va después de la Comparativa, justo cuando el visitante se ha visto reflejado. */
---
<section class="section-padding lead-band">
  <div class="container-narrow lead-band-inner reveal">
    <p class="lead-band-text">¿Cuánto te cuesta a ti el papeleo? Pregúntaselo a LucIA.</p>
    <button type="button" class="btn btn-white lead-band-cta" data-open-lucia>Echa cuentas gratis</button>
  </div>
</section>

<style>
  .lead-band { background: var(--color-ink); }
  .lead-band-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .lead-band-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  .lead-band-text {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.3;
    max-width: 28ch;
  }
  .lead-band-cta { flex: none; }
</style>
