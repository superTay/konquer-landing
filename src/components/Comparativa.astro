---
/** Comparativa.astro — Semana sin vs con KonquerAI. Copy literal de 06. */
const rows = [
  { sin: "Lunes: cliente nuevo pide presupuesto. Le dices «esta tarde te lo paso».", con: "Lunes: cliente nuevo pide presupuesto. Lo haces en 5 minutos desde la obra y se lo envías antes de salir." },
  { sin: "Martes: facturas de proveedores acumuladas en el email. Las dejas para «después».", con: "Martes: las facturas ya están en la app, clasificadas. Solo apruebas en 3 segundos." },
  { sin: "Miércoles: la gestoría te pide los gastos del mes. Buscas en 6 carpetas distintas.", con: "Miércoles: tu gestoría tiene acceso de lectura. No te pide nada." },
  { sin: "Jueves: terminas una obra. No tienes ni idea de si fue rentable.", con: "Jueves: terminas una obra. La app te dice «1.840 € de margen, semáforo verde»." },
  { sin: "Viernes: cliente te debe 3.400 € desde hace 47 días. Te acabas de acordar.", con: "Viernes: el sistema le mandó recordatorio el día 30. Ya está pagada." },
  { sin: "Domingo, 22:30: cena fría, tres facturas por hacer.", con: "Domingo, 22:30: cena con la familia. La app ya cerró el día." },
];
---
<section class="section-padding bg-mist" id="comparativa">
  <div class="container-narrow">
    <h2 class="comp-h2">Una semana sin KonquerAI vs una semana con KonquerAI.</h2>
    <div class="comp-table">
      <div class="comp-header">
        <span class="comp-label comp-label-sin">Sin KonquerAI</span>
        <span class="comp-label comp-label-con">Con KonquerAI</span>
      </div>
      {rows.map(row => (
        <div class="comp-row">
          <div class="comp-cell comp-cell-sin">{row.sin}</div>
          <div class="comp-cell comp-cell-con">{row.con}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .comp-h2 { text-align: center; margin-bottom: 3rem; }
  .comp-table {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-white);
  }
  .comp-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--color-ink);
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .comp-label { padding: 1rem 1.25rem; }
  .comp-label-con { background: var(--color-teal); }
  .comp-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--color-border);
  }
  .comp-cell {
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-slate);
  }
  .comp-cell-con {
    background: var(--color-teal-light);
    color: var(--color-ink);
    font-weight: 500;
  }
  @media (max-width: 767px) {
    .comp-header, .comp-row {
      grid-template-columns: 1fr;
    }
    .comp-label-sin { border-bottom: 1px solid rgba(255,255,255,0.15); }
    .comp-cell-sin { border-bottom: 1px solid var(--color-border); }
  }
</style>
