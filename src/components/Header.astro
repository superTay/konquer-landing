---
/**
 * Header.astro — Liquid glass floating navbar
 * backdrop-filter blur + semi-transparent white + soft shadow
 * High contrast nav for older users (16px min, weight 500)
 */
import Logo from "./Logo.astro";
---

<header class="header" id="header">
  <div class="header-inner">
    <Logo height={50} class="header-logo" />

    <!-- Desktop nav -->
    <nav class="header-nav" aria-label="Navegación principal">
      <a href="/#como-funciona" class="nav-link">Cómo funciona</a>
      <a href="/#pricing" class="nav-link">Precios</a>
      <a href="/#para-quien" class="nav-link">Para quién</a>
      <a href="/#faq" class="nav-link">Verifactu</a>
      <a href="https://app.konquerai.com" rel="noopener" class="header-login btn btn-secondary">Acceder</a>
      <a href="/#contacto" class="header-cta btn btn-primary">Pide tu demo</a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      class="mobile-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" class="line line-top" />
        <line x1="3" y1="12" x2="21" y2="12" class="line line-mid" />
        <line x1="3" y1="18" x2="21" y2="18" class="line line-bot" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <nav class="mobile-menu" id="mobile-menu" aria-label="Menú móvil" hidden>
    <a href="/#como-funciona" class="mobile-link">Cómo funciona</a>
    <a href="/#pricing" class="mobile-link">Precios</a>
    <a href="/#para-quien" class="mobile-link">Para quién</a>
    <a href="/#faq" class="mobile-link">Verifactu</a>
    <a href="https://app.konquerai.com" rel="noopener" class="btn btn-secondary mobile-cta">Acceder</a>
    <a href="/#contacto" class="btn btn-primary mobile-cta">Pide tu demo</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('header');

  toggle?.addEventListener('click', () => {
    const open = menu?.hidden === false;
    menu!.hidden = !menu!.hidden;
    toggle.setAttribute('aria-expanded', String(!open));
    header?.classList.toggle('menu-open', !open);
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu!.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
      header?.classList.remove('menu-open');
    });
  });
</script>

<style>
  /* ── Floating liquid-glass pill (Apple Vision Pro style) ── */
  .header {
    position: sticky;
    top: 0.75rem;
    z-index: 100;
    padding-inline: clamp(1rem, 4vw, 2rem);
    transition: top 0.35s var(--ease-out-expo);
  }

  .header-inner {
    max-width: 1180px;
    margin-inline: auto;
    padding: 0 0.75rem 0 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.75),
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 12px 32px -12px rgba(11, 31, 36, 0.18);
    transition:
      height 0.35s var(--ease-out-expo),
      max-width 0.35s var(--ease-out-expo),
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  /* Smooth logo resize alongside the pill */
  :global(.header-logo .logo-img) {
    transition: height 0.35s var(--ease-out-expo);
  }

  /* ── Condensed state on scroll ── */
  .header.is-scrolled {
    top: 0.5rem;
  }

  .header.is-scrolled .header-inner {
    height: 56px;
    max-width: 1080px;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(28px) saturate(1.7);
    -webkit-backdrop-filter: blur(28px) saturate(1.7);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 8px 24px -10px rgba(11, 31, 36, 0.24);
  }

  .header.is-scrolled :global(.header-logo .logo-img) {
    height: 44px;
  }

  .header.menu-open .header-inner {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 12px 32px -8px rgba(11, 31, 36, 0.22);
  }

  /* ── Desktop nav ── */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: color 0.2s ease;
    position: relative;
    padding-block: 0.25rem;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--color-teal);
    border-radius: 1px;
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    color: var(--color-teal);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .header-cta,
  .header-login {
    padding: 0.625rem 1.5rem;
    min-height: 44px;
    font-size: 0.9375rem;
  }

  /* ── Mobile toggle ── */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
    transition: background 0.2s;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .mobile-toggle:hover {
    background: var(--color-mist);
  }

  .line {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .menu-open .line-top {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-open .line-mid {
    opacity: 0;
  }
  .menu-open .line-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Mobile drawer ── */
  .mobile-menu {
    display: none;
  }

  .mobile-menu:not([hidden]) {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
    padding: 0.75rem;
    gap: 0.25rem;
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 16px 40px -12px rgba(11, 31, 36, 0.25);
    animation: slideDown 0.25s ease;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .mobile-link {
    display: block;
    padding: 0.875rem 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }

  .mobile-link:hover {
    background: var(--color-mist);
    color: var(--color-teal);
  }

  .mobile-cta {
    margin-top: 0.5rem;
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .header-nav {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
  }

  @media (min-width: 768px) {
    .mobile-menu,
    .mobile-menu:not([hidden]) {
      display: none !important;
    }
  }
</style>
