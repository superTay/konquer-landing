---
/** Demo.astro — Demo visual / producto en acción. 3 screenshots placeholder. */
---
<section class="section-padding bg-mist" id="demo">
  <div class="container-narrow">
    <h2 class="demo-h2">Esto es lo que ves cuando abres la app.</h2>
    <div class="demo-grid">
      <div class="demo-item">
        <div class="demo-frame">
          <img src="/screenshots/demo-kpis.png" alt="Placeholder — Panel KPIs: pendiente de cobro, cobrado mes, pipeline activo, IVA trimestre" width="400" height="280" loading="lazy" class="demo-img" />
          <span class="placeholder-badge">Placeholder</span>
        </div>
        <p class="demo-caption">El estado del negocio en tres segundos.</p>
      </div>
      <div class="demo-item">
        <div class="demo-frame">
          <img src="/screenshots/demo-rentabilidad.png" alt="Placeholder — Ranking de rentabilidad por obra con semáforo" width="400" height="280" loading="lazy" class="demo-img" />
          <span class="placeholder-badge">Placeholder</span>
        </div>
        <p class="demo-caption">Sabes obra a obra qué te dio dinero y qué te lo quitó.</p>
      </div>
      <div class="demo-item">
        <div class="demo-frame">
          <img src="/screenshots/demo-chat.png" alt="Placeholder — Chat de presupuesto móvil" width="400" height="280" loading="lazy" class="demo-img" />
          <span class="placeholder-badge">Placeholder</span>
        </div>
        <p class="demo-caption">Presupuesto en 5 minutos. Desde la furgoneta.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-h2 { text-align: center; margin-bottom: 3rem; }
  .demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .demo-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .demo-item { text-align: center; }
  .demo-frame {
    position: relative;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .demo-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: linear-gradient(135deg, var(--color-teal-light), var(--color-white), var(--color-mist));
  }
  .demo-caption {
    margin-top: 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
  }
  .placeholder-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.625rem;
    background: var(--color-orange-light);
    color: var(--color-orange);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
