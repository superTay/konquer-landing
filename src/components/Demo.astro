---
/** Demo.astro — Comparativa Web vs Móvil (puntos 4/5/6). Dos paneles enfrentados con
 *  capturas reales. Web = negocio centralizado; Móvil = el día a día. */
import { Image } from "astro:assets";
import webShot from "../assets/screenshots/factura-recibida-web.png";
import mobileShot from "../assets/screenshots/mobile-generando.png";
---
<section class="section-padding" id="demo">
  <div class="container-narrow">
    <h2 class="demo-h2 reveal">La oficina, en el ordenador. El día a día, en el móvil.</h2>
    <p class="demo-intro reveal">El mismo negocio, lo lleves desde donde lo lleves. Cada cosa, en su sitio.</p>

    <div class="demo-panels">
      <!-- WEB: todo centralizado -->
      <article class="demo-panel reveal">
        <div class="demo-panel-media">
          <div class="browser-frame">
            <div class="browser-bar" aria-hidden="true"><span></span><span></span><span></span></div>
            <Image
              src={webShot}
              alt="Panel web de KonquerAI: el inicio del negocio con las tareas del día y las facturas recibidas pendientes de revisar"
              width={900}
              densities={[1, 2]}
              loading="lazy"
              class="browser-shot"
            />
          </div>
        </div>
        <div class="demo-panel-text">
          <span class="demo-panel-tag">En el ordenador</span>
          <h3>La web: tu negocio entero, en un sitio.</h3>
          <ul class="demo-list">
            <li>Las facturas, ordenadas por proveedor: albaranes y facturas, cada uno por su lado y sumados por periodo.</li>
            <li>La rentabilidad de cada obra: cuánto te cuesta el material y cuánto te queda de verdad.</li>
            <li>Conciliación de albaranes: cuando llega la factura recapitulativa, ves en dos clics si hay duplicados y si cuadra.</li>
            <li>Tus clientes, creados solos con cada factura.</li>
            <li>Las métricas de tu negocio y la configuración de tus asistentes.</li>
          </ul>
        </div>
      </article>

      <!-- MÓVIL: el día a día -->
      <article class="demo-panel demo-panel-mobile reveal">
        <div class="demo-panel-media">
          <Image
            src={mobileShot}
            alt="App de KonquerAI en el móvil generando un presupuesto por voz desde la obra"
            width={440}
            densities={[1, 2]}
            loading="lazy"
            class="phone-shot"
          />
        </div>
        <div class="demo-panel-text">
          <span class="demo-panel-tag">En el móvil</span>
          <h3>El móvil: tu día a día.</h3>
          <ul class="demo-list">
            <li>Presupuestos hablando o por chat. Los mandas por WhatsApp o correo antes de salir de la obra. Listo en un par de minutos.</li>
            <li>Facturas al momento: desde el chat o desde un presupuesto que el cliente acepta.</li>
            <li>Escaneas las facturas de papel y el sistema las ordena por ti.</li>
            <li>Validas las facturas que te llegan con un vistazo.</li>
          </ul>
        </div>
      </article>
    </div>

    <p class="demo-sync reveal">Lo que haces en el móvil aparece en la web al instante. Es el mismo negocio, vayas con el teléfono o te sientes en el ordenador.</p>
  </div>
</section>

<style>
  .demo-h2 { text-align: center; margin-bottom: 1rem; }
  .demo-intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
    color: var(--color-slate);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .demo-panels {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .demo-panel {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .demo-panels { gap: 5.5rem; }
    .demo-panel { grid-template-columns: 1fr 1fr; gap: 4rem; }
    /* El panel móvil invierte el orden (captura a la derecha) */
    .demo-panel-mobile .demo-panel-media { order: 2; }
    .demo-panel-mobile .demo-panel-text { order: 1; }
  }

  /* ── Media ── */
  .demo-panel-media { display: flex; justify-content: center; }

  .phone-shot {
    width: 260px;
    max-width: 100%;
    height: auto;
    border-radius: 30px;
    box-shadow: 0 24px 70px rgba(11, 31, 36, 0.18);
  }

  .browser-frame {
    width: 100%;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card-hover);
  }
  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    height: 34px;
    padding-inline: 0.9rem;
    background: var(--color-mist);
    border-bottom: 1px solid var(--color-border);
  }
  .browser-bar span {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-border);
  }
  .browser-shot { width: 100%; height: auto; display: block; }

  /* ── Texto ── */
  .demo-panel-tag {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .demo-panel-text h3 {
    font-size: 1.5rem;
    line-height: 1.25;
    margin-bottom: 1.25rem;
    color: var(--color-ink);
  }
  .demo-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .demo-list li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--color-slate);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .demo-list li::before {
    content: "";
    position: absolute;
    left: 0.1rem;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background: var(--color-teal);
  }

  .demo-sync {
    text-align: center;
    max-width: 640px;
    margin: 4rem auto 0;
    font-weight: 600;
    color: var(--color-ink);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  /* ── Parallax sutil en las capturas: scroll-driven nativo, cero JS ── */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .demo-panel-media {
        animation: demo-parallax linear both;
        animation-timeline: view();
        animation-range: cover 0% cover 100%;
        will-change: transform;
      }
      @keyframes demo-parallax {
        from { transform: translateY(20px); }
        to   { transform: translateY(-20px); }
      }
    }
  }
</style>
