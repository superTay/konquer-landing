---
/** Demo.astro — Demo visual / producto en acción. Capturas reales en filas alternas.
 * Captions LITERALES de 06_homepage_copy.md. */
import { Image } from "astro:assets";
import demoKpisWeb from "../assets/screenshots/demo-kpis-web.png";
import demoRentabilidad from "../assets/screenshots/demo-rentabilidad.png";
import demoChat from "../assets/screenshots/demo-chat.png";
import demoFacturasRecibidas from "../assets/screenshots/factura-recibida.png";
---
<section class="section-padding bg-mist" id="demo">
  <div class="container-narrow">
    <h2 class="demo-h2 reveal">Esto es lo que ves cuando abres la app.</h2>

    <div class="demo-rows">
      <article class="demo-row reveal">
        <div class="demo-media">
          <div class="browser-frame">
            <div class="browser-bar" aria-hidden="true"><span></span><span></span><span></span></div>
            <Image
              src={demoKpisWeb}
              alt="Panel de inicio de la app en web: pendiente de cobro, cobrado del mes, pipeline, IVA del trimestre y la gráfica de ingresos vs gastos"
              width={960}
              densities={[1, 2]}
              loading="lazy"
              class="browser-shot"
            />
          </div>
        </div>
        <div class="demo-text">
          <span class="demo-num">01</span>
          <h3 class="demo-caption">El estado del negocio en tres segundos.</h3>
        </div>
      </article>

      <article class="demo-row reveal">
        <div class="demo-media">
          <div class="browser-frame">
            <div class="browser-bar" aria-hidden="true"><span></span><span></span><span></span></div>
            <Image
              src={demoRentabilidad}
              alt="Ranking de rentabilidad por obra con semáforo: margen en verde, alerta en naranja y sobrecoste en rojo"
              width={960}
              densities={[1, 2]}
              loading="lazy"
              class="browser-shot"
            />
          </div>
        </div>
        <div class="demo-text">
          <span class="demo-num">02</span>
          <h3 class="demo-caption">Sabes obra a obra qué te dio dinero y qué te lo quitó.</h3>
        </div>
      </article>

      <article class="demo-row reveal">
        <div class="demo-media">
          <Image
            src={demoChat}
            alt="Presupuesto por chat: hablas, la app anota las partidas y monta el presupuesto"
            width={520}
            densities={[1, 2]}
            loading="lazy"
            class="phone-shot"
          />
        </div>
        <div class="demo-text">
          <span class="demo-num">03</span>
          <h3 class="demo-caption">Presupuesto en 5 minutos. Desde la furgoneta.</h3>
        </div>
      </article>

      <article class="demo-row reveal">
        <div class="demo-media">
          <Image
            src={demoFacturasRecibidas}
            alt="Pestaña de facturas recibidas: total gastado, IVA soportado y la lista de facturas marcadas como recibidas automáticamente"
            width={520}
            densities={[1, 2]}
            loading="lazy"
            class="phone-shot"
          />
        </div>
        <div class="demo-text">
          <span class="demo-num">04</span>
          <h3 class="demo-caption">Las facturas de proveedor, ordenadas sin que muevas un dedo.</h3>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .demo-h2 { text-align: center; margin-bottom: 3.5rem; }

  .demo-rows {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .demo-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .demo-rows { gap: 6rem; }
    .demo-row { grid-template-columns: 1fr 1fr; gap: 4rem; }
    /* Filas pares: invertir orden para zig-zag */
    .demo-row:nth-child(even) .demo-media { order: 2; }
    .demo-row:nth-child(even) .demo-text { order: 1; }
  }

  /* ── Lado media ── */
  .demo-media {
    display: flex;
    justify-content: center;
  }

  .phone-shot {
    width: 270px;
    max-width: 100%;
    height: auto;
    border-radius: 30px;
    box-shadow: 0 24px 70px rgba(11, 31, 36, 0.18);
  }

  .browser-frame {
    width: 100%;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card-hover);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    height: 34px;
    padding-inline: 0.9rem;
    background: var(--color-mist);
    border-bottom: 1px solid var(--color-border);
  }

  .browser-bar span {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-border);
  }

  .browser-shot {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Lado texto ── */
  .demo-num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .demo-caption {
    font-size: 1.5rem;
    line-height: 1.25;
    max-width: 420px;
  }

  @media (max-width: 767px) {
    .demo-text { text-align: center; }
    .demo-caption { margin-inline: auto; }
  }

  /* ── Parallax sutil en las capturas: scroll-driven nativo, cero JS ── */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .demo-media {
        animation: demo-parallax linear both;
        animation-timeline: view();
        animation-range: cover 0% cover 100%;
        will-change: transform;
      }
      @keyframes demo-parallax {
        from { transform: translateY(22px); }
        to   { transform: translateY(-22px); }
      }
    }
  }
</style>
