---
// Widget "Tu consultor de Obra" — burbuja + panel de chat. Mobile-first.
// La lógica vive en chatbot.client.ts; el copy/marca en config/*.json.
import brand from './config/brand.json';
import reportCopy from './config/report-copy.json';

const bot = brand.bot;
const contador = (reportCopy as any).contador_vivo;
---

<div id="konker-chat" data-state="closed">
  <!-- Burbuja -->
  <button
    id="kc-bubble"
    class="kc-bubble"
    type="button"
    aria-label={`Abrir ${bot.nombre}`}
    aria-expanded="false"
    aria-controls="kc-panel"
  >
    <svg class="kc-ico kc-ico-chat" viewBox="0 0 24 24" aria-hidden="true" fill="none">
      <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5Z"
        stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="kc-bubble-label">{bot.saludo_burbuja}</span>
  </button>

  <!-- Panel -->
  <div
    id="kc-panel"
    class="kc-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="kc-title"
    hidden
  >
    <header class="kc-header">
      <span class="kc-avatar" aria-hidden="true">{bot.avatar_iniciales}</span>
      <span class="kc-headtext">
        <span id="kc-title" class="kc-title">{bot.nombre}</span>
        <span class="kc-subtitle">{bot.subtitulo}</span>
      </span>
      <button id="kc-close" class="kc-icon-btn kc-close" type="button" aria-label="Cerrar el chat">
        <svg class="kc-ico" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <!-- Contador de ahorro en vivo (aparece tras la P7) -->
    <div id="kc-counter" class="kc-counter" hidden aria-live="polite">
      <span id="kc-counter-label" class="kc-counter-label">{contador?.prefijo}&nbsp;</span>
      <strong id="kc-counter-value" class="kc-counter-value" data-raw="0">0&nbsp;€</strong>
      <span class="kc-counter-suffix">&nbsp;{contador?.sufijo}</span>
    </div>

    <div id="kc-messages" class="kc-messages" role="log" aria-live="polite" aria-atomic="false"></div>

    <form id="kc-form" class="kc-input" autocomplete="off">
      <button id="kc-mic" class="kc-icon-btn kc-mic" type="button" aria-label="Hablar por voz">
        <svg class="kc-ico" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <path d="M12 15a3 3 0 0 0 3-3V6a3 3 0 1 0-6 0v6a3 3 0 0 0 3 3Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M19 11a7 7 0 0 1-14 0M12 18v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <input
        id="kc-text"
        class="kc-textfield"
        type="text"
        name="kc-text"
        placeholder="Escribe tu respuesta..."
        aria-label="Tu respuesta"
        autocomplete="off"
        enterkeyhint="send"
      />
      <button id="kc-send" class="kc-icon-btn kc-send" type="submit" aria-label="Enviar">
        <svg class="kc-ico" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <path d="M4 12l16-8-6 16-3-7-7-1Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>

    <p class="kc-legal">
      Al dejarme tu correo aceptas la <a href={brand.legal.enlace_privacidad}>política de privacidad</a>. Nada de spam.
    </p>
  </div>
</div>

<script>
  import './chatbot.client.ts';
</script>

<style>
  :root {
    --kc-teal: var(--color-teal, #00D1B2);
    --kc-teal-dark: var(--color-teal-dark, #009B89);
    --kc-orange: var(--color-orange, #FF8A00);
    --kc-ink: var(--color-ink, #0B1F24);
    --kc-slate: var(--color-slate, #4B5563);
    --kc-mist: var(--color-mist, #F6F8F9);
    --kc-border: var(--color-border, #E5EAEC);
    --kc-white: var(--color-white, #fff);
    --kc-z: 9999;
  }

  #konker-chat { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }

  /* ---------- Burbuja ---------- */
  .kc-bubble {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: var(--kc-z);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 56px;
    padding: 0 1.1rem 0 0.95rem;
    border: none;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--kc-teal) 0%, var(--kc-teal-dark) 100%);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 10px 30px -8px rgba(0, 155, 137, 0.55);
    transition: transform 200ms ease-out, box-shadow 200ms ease-out;
  }
  .kc-bubble:hover { box-shadow: 0 14px 38px -8px rgba(0, 155, 137, 0.65); }
  .kc-bubble:focus-visible { outline: 3px solid var(--kc-ink); outline-offset: 2px; }
  .kc-ico-chat { width: 26px; height: 26px; flex: none; }
  .kc-bubble-label {
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
    max-width: 14rem;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #konker-chat[data-state="open"] .kc-bubble { display: none; }

  /* ---------- Panel ---------- */
  .kc-panel {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: var(--kc-z);
    display: flex;
    flex-direction: column;
    width: min(380px, calc(100vw - 2rem));
    height: min(640px, calc(100dvh - 2rem));
    background: var(--kc-white);
    border: 1px solid var(--kc-border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 24px 60px -16px rgba(11, 31, 36, 0.32);
  }
  #konker-chat[data-state="open"] .kc-panel { animation: kc-in 220ms ease-out; }
  @keyframes kc-in {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ---------- Header ---------- */
  .kc-header {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1rem;
    background: linear-gradient(135deg, var(--kc-teal) 0%, var(--kc-teal-dark) 100%);
    color: #fff;
  }
  .kc-avatar {
    flex: none;
    width: 40px; height: 40px;
    display: grid; place-items: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.18);
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .kc-headtext { display: flex; flex-direction: column; line-height: 1.2; flex: 1; min-width: 0; }
  .kc-title { font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.02rem; }
  .kc-subtitle { font-size: 0.78rem; opacity: 0.85; }

  .kc-icon-btn {
    flex: none;
    display: grid; place-items: center;
    width: 44px; height: 44px;
    border: none; border-radius: 9999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background-color 200ms ease;
  }
  .kc-icon-btn:focus-visible { outline: 3px solid var(--kc-ink); outline-offset: 2px; }
  .kc-ico { width: 22px; height: 22px; }
  .kc-close:hover { background: rgba(255, 255, 255, 0.18); }

  /* ---------- Contador en vivo ---------- */
  .kc-counter {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.15rem;
    padding: 0.6rem 1rem;
    background: var(--color-orange-light, #FFF3E0);
    border-bottom: 1px solid var(--kc-border);
    font-size: 0.82rem;
    color: var(--kc-slate);
  }
  .kc-counter-value {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--kc-orange);
  }

  /* ---------- Mensajes ---------- */
  .kc-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--kc-mist);
    -webkit-overflow-scrolling: touch;
  }
  .kc-msg { display: flex; }
  .kc-msg-assistant { justify-content: flex-start; }
  .kc-msg-user { justify-content: flex-end; }
  .kc-bubble-text {
    max-width: 85%;
    padding: 0.62rem 0.85rem;
    border-radius: 16px;
    font-size: 1rem;            /* 16px: legible y evita el zoom en iOS */
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .kc-msg-assistant .kc-bubble-text {
    background: var(--kc-white);
    color: var(--kc-ink);
    border: 1px solid var(--kc-border);
    border-bottom-left-radius: 5px;
  }
  .kc-msg-user .kc-bubble-text {
    background: var(--kc-teal);
    color: #fff;
    border-bottom-right-radius: 5px;
  }

  /* Typing */
  .kc-typing .kc-bubble-text { display: inline-flex; gap: 4px; align-items: center; }
  .kc-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--kc-slate); opacity: 0.5;
    animation: kc-blink 1.2s infinite ease-in-out;
  }
  .kc-dot:nth-child(2) { animation-delay: 0.2s; }
  .kc-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes kc-blink { 0%, 80%, 100% { opacity: 0.25; } 40% { opacity: 0.9; } }

  /* ---------- Input ---------- */
  .kc-input {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem;
    border-top: 1px solid var(--kc-border);
    background: var(--kc-white);
  }
  .kc-textfield {
    flex: 1;
    min-width: 0;
    height: 44px;
    padding: 0 0.95rem;
    border: 1.5px solid var(--kc-border);
    border-radius: 9999px;
    font-size: 1rem;           /* 16px obligatorio para iOS */
    font-family: inherit;
    color: var(--kc-ink);
    background: var(--kc-white);
  }
  .kc-textfield:focus-visible { outline: none; border-color: var(--kc-teal); box-shadow: 0 0 0 3px rgba(0, 209, 178, 0.18); }
  .kc-textfield:disabled { opacity: 0.6; }

  .kc-mic { border: 1.5px solid var(--kc-border); color: var(--kc-slate); }
  .kc-mic:hover { background: var(--kc-mist); }
  .kc-mic-on { color: #fff; background: var(--kc-orange); border-color: var(--kc-orange); animation: kc-pulse 1.2s infinite; }
  @keyframes kc-pulse { 0% { box-shadow: 0 0 0 0 rgba(255, 138, 0, 0.5); } 100% { box-shadow: 0 0 0 10px rgba(255, 138, 0, 0); } }

  .kc-send { background: var(--kc-teal); color: #fff; }
  .kc-send:hover { background: var(--kc-teal-dark); }
  .kc-send:disabled, .kc-mic:disabled { opacity: 0.5; cursor: default; }

  .kc-legal {
    margin: 0;
    padding: 0 0.9rem 0.7rem;
    font-size: 0.7rem;
    color: var(--kc-slate);
    background: var(--kc-white);
    text-align: center;
  }
  .kc-legal a { color: var(--kc-teal); text-decoration: underline; }

  /* ---------- Móvil: pantalla completa ---------- */
  @media (max-width: 640px) {
    .kc-bubble { right: 0.85rem; bottom: 0.85rem; }
    .kc-bubble-label { display: none; }          /* solo el icono en móvil */
    .kc-bubble { padding: 0; width: 56px; justify-content: center; }
    .kc-panel {
      right: 0; bottom: 0; left: 0; top: 0;
      width: 100%; height: auto;       /* inset:0 define la altura: cubre toda la pantalla */
      max-height: none;
      border: none; border-radius: 0;
      padding-bottom: env(safe-area-inset-bottom, 0);  /* notch/barra de gestos */
    }
    #konker-chat[data-state="open"] .kc-panel { animation: kc-in-mobile 220ms ease-out; }
    @keyframes kc-in-mobile { from { transform: translateY(100%); } to { transform: translateY(0); } }
  }

  @media (prefers-reduced-motion: reduce) {
    .kc-bubble, .kc-panel, .kc-dot, .kc-mic-on { animation: none !important; transition: none !important; }
  }
</style>
