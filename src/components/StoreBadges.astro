---
/**
 * StoreBadges.astro — Badges de App Store y Google Play.
 * Reutilizable (bloque "La app" + footer). `size`: "lg" (default) | "sm".
 * TODO: sustituir href="#" por las URLs reales de las fichas de tienda.
 */
interface Props {
  size?: "lg" | "sm";
  class?: string;
}
const { size = "lg", class: extraClass = "" } = Astro.props;
const APP_STORE_URL = "#"; // TODO: URL real de App Store
const GOOGLE_PLAY_URL = "#"; // TODO: URL real de Google Play
---
<div class:list={["store-badges", `store-badges-${size}`, extraClass]}>
  <a class="store-badge" href={APP_STORE_URL} aria-label="Descárgala en el App Store">
    <svg class="store-badge-ico" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.05 12.04c-.03-2.6 2.13-3.85 2.23-3.91-1.22-1.78-3.11-2.02-3.78-2.05-1.61-.16-3.14.95-3.96.95-.81 0-2.07-.93-3.41-.9-1.75.03-3.37 1.02-4.27 2.59-1.82 3.16-.47 7.84 1.3 10.41.86 1.26 1.89 2.67 3.23 2.62 1.3-.05 1.79-.84 3.36-.84 1.57 0 2.01.84 3.38.81 1.4-.02 2.28-1.28 3.13-2.55.99-1.46 1.4-2.87 1.42-2.94-.03-.01-2.72-1.04-2.75-4.14zM14.6 4.7c.72-.87 1.2-2.08 1.07-3.28-1.03.04-2.28.69-3.02 1.56-.66.77-1.24 2-1.08 3.18 1.15.09 2.32-.59 3.03-1.46z"/>
    </svg>
    <span class="store-badge-text">
      <span class="store-badge-top">Descárgala en el</span>
      <span class="store-badge-name">App Store</span>
    </span>
  </a>

  <a class="store-badge" href={GOOGLE_PLAY_URL} aria-label="Disponible en Google Play">
    <svg class="store-badge-ico" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="#00C3FF" d="M3.6 2.2a1.3 1.3 0 0 0-.5 1.06v17.48c0 .47.18.85.5 1.06L13.5 12 3.6 2.2z"/>
      <path fill="#FFCE00" d="M17.2 8.3 13.5 12l3.7 3.7 4.38-2.49c.73-.41.73-1.6 0-2.02L17.2 8.3z"/>
      <path fill="#00F076" d="M3.6 2.2 13.5 12l3.7-3.7L6.02 2.08c-.92-.52-1.83-.42-2.42.12z"/>
      <path fill="#FF3A44" d="M3.6 21.8c.59.54 1.5.64 2.42.12L17.2 15.7 13.5 12 3.6 21.8z"/>
    </svg>
    <span class="store-badge-text">
      <span class="store-badge-top">Disponible en</span>
      <span class="store-badge-name">Google Play</span>
    </span>
  </a>
</div>

<style>
  .store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }
  .store-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    background: var(--color-ink);
    color: var(--color-white);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    padding: 0.5rem 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .store-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(11, 31, 36, 0.25);
  }
  .store-badge-ico { flex: none; width: 26px; height: 26px; }
  .store-badge-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    text-align: left;
  }
  .store-badge-top {
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }
  .store-badge-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
  }

  /* Tamaño compacto para el footer */
  .store-badges-sm .store-badge { padding: 0.4rem 0.8rem; border-radius: 8px; }
  .store-badges-sm .store-badge-ico { width: 20px; height: 20px; }
  .store-badges-sm .store-badge-top { font-size: 0.5625rem; }
  .store-badges-sm .store-badge-name { font-size: 0.875rem; }

  /* Variante grande: dos badges de igual ancho con el símbolo + texto centrados.
     Apilan en pantallas estrechas manteniendo el centrado. */
  .store-badges-lg .store-badge { flex: 1 1 200px; max-width: 220px; }
</style>
