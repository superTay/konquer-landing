---
/** Cifras.astro — Banda oscura con contadores animados.
 *  Sobre fondo oscuro los glows teal lucen de verdad (contraste = wow).
 *  Cifras ancladas al copy real (hero, Pilares, FacturasRecibidas). No inventadas.
 *  Los números cuentan al entrar en viewport (JS en Base.astro, gated reduced-motion).
 */
const cifras = [
  { n: 30, suffix: "", label: "horas al mes que dejas de perder en papeleo" },
  { n: 90, suffix: " %", label: "de autónomos no sabe qué obra le da dinero. Tú sí." },
  { n: 5, suffix: " s", label: "para aprobar una factura de proveedor" },
];
---
<section class="cifras" id="cifras" aria-label="KonquerAI en números">
  <span class="cifras-glow" aria-hidden="true"></span>
  <div class="grain" aria-hidden="true"></div>
  <div class="container-narrow cifras-grid reveal-stagger">
    {cifras.map((c) => (
      <div class="cifra reveal">
        <span class="cifra-num" data-counter={c.n} data-suffix={c.suffix}>0{c.suffix}</span>
        <p class="cifra-label">{c.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .cifras {
    position: relative;
    overflow: hidden;
    background: var(--color-ink);
    padding-block: 4.5rem;
  }

  .cifras-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60rem;
    height: 40rem;
    max-width: 120vw;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(40% 50% at 30% 42%, rgba(0, 209, 178, 0.22), transparent 70%),
      radial-gradient(36% 46% at 72% 58%, rgba(255, 138, 0, 0.12), transparent 70%);
    filter: blur(30px);
    pointer-events: none;
  }

  .cifras :global(.grain) {
    opacity: 0.06;
  }

  .cifras-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cifras-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .cifra-num {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(3rem, 7vw, 4.5rem);
    line-height: 1;
    color: var(--color-teal);
    letter-spacing: -0.02em;
    text-shadow: 0 0 28px rgba(0, 209, 178, 0.45);
    font-variant-numeric: tabular-nums;
  }

  .cifra-label {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 22rem;
    margin-inline: auto;
  }
</style>
