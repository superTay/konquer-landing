---
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/plus-jakarta-sans/400.css';
import '@fontsource/plus-jakarta-sans/500.css';
import '@fontsource/plus-jakarta-sans/600.css';
import '@fontsource/plus-jakarta-sans/700.css';
import '../styles/global.css';
import Chatbot from '../components/Chatbot/Chatbot.astro';
import Report from '../components/Chatbot/Report.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "KonquerAI · Software de gestión para autónomos de reformas con IA",
  description = "Recupera hasta 30 horas al mes y sabe qué obra te dio dinero. Presupuestos, facturas, IVA y Verifactu sin aprender tecnología. Para pintores, albañiles, electricistas y fontaneros. Garantía 30 días.",
  noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://www.konquerai.com").href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Verificación de buscadores -->
    <meta name="msvalidate.01" content="03438030CF712F11EBC711787FAF21CA" />
    <meta name="google-site-verification" content="w0T7YcAOuuxkrM1x0M0L0-VD5xV1T5QFFyZyim8r5d8" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="KonquerAI" />
    <meta property="og:title" content="KonquerAI · Tu cuadrilla administrativa, ahora digital" />
    <meta property="og:description" content="Recupera 30 horas al mes. Controla cada obra al céntimo. Sin Excel, sin gestoría sufriendo. Hecho para autónomos de reformas." />
    <meta property="og:image" content="https://www.konquerai.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="KonquerAI — Tu cuadrilla administrativa, ahora digital" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="KonquerAI · Tu cuadrilla administrativa, ahora digital" />
    <meta name="twitter:description" content="Recupera 30 horas al mes. Controla cada obra al céntimo. Sin Excel, sin gestoría sufriendo. Hecho para autónomos de reformas." />
    <meta name="twitter:image" content="https://www.konquerai.com/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts: Outfit + Plus Jakarta Sans — self-hosted via @fontsource (imports en el frontmatter) -->

    <!-- Estilos globales importados en el frontmatter (procesados por Tailwind v4) -->

    <!-- Schema.org — grafo de entidad (Organization + Person + WebSite + SoftwareApplication).
         sameAs Organization: Wikidata + Crunchbase. Person: LinkedIn personal.
         Pendiente de añadir cuando existan: página de empresa en LinkedIn y Google Business Profile. -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.konquerai.com/#organization",
          "name": "KonquerAI",
          "legalName": "Christian Marzal Della-Rovere",
          "url": "https://www.konquerai.com",
          "logo": {
            "@type": "ImageObject",
            "url": "https://www.konquerai.com/og-image.png",
            "width": 1200,
            "height": 630
          },
          "image": "https://www.konquerai.com/og-image.png",
          "description": "Software de gestión administrativa para autónomos de reformas: presupuestos, facturas, IVA y Verifactu, con acompañamiento humano real.",
          "email": "info@konquerai.com",
          "foundingDate": "2026",
          "areaServed": { "@type": "Country", "name": "España" },
          "knowsLanguage": "es-ES",
          "founder": { "@id": "https://www.konquerai.com/#founder" },
          "contactPoint": {
            "@type": "ContactPoint",
            "email": "info@konquerai.com",
            "contactType": "atención al cliente",
            "availableLanguage": "Spanish",
            "areaServed": "ES"
          },
          "sameAs": [
            "https://www.wikidata.org/wiki/Q140277090",
            "https://www.crunchbase.com/organization/konquerai"
          ]
        },
        {
          "@type": "Person",
          "@id": "https://www.konquerai.com/#founder",
          "name": "Christian Marzal Della-Rovere",
          "jobTitle": "Fundador",
          "worksFor": { "@id": "https://www.konquerai.com/#organization" },
          "sameAs": [
            "https://www.linkedin.com/in/christian-marzal-della-rovere"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://www.konquerai.com/#website",
          "url": "https://www.konquerai.com",
          "name": "KonquerAI",
          "description": "Tu cuadrilla administrativa, ahora digital. Para autónomos de reformas.",
          "inLanguage": "es-ES",
          "publisher": { "@id": "https://www.konquerai.com/#organization" }
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://www.konquerai.com/#app",
          "name": "KonquerAI",
          "url": "https://www.konquerai.com",
          "applicationCategory": "BusinessApplication",
          "applicationSubCategory": "FinanceApplication",
          "operatingSystem": "Web, iOS, Android",
          "inLanguage": "es-ES",
          "image": "https://www.konquerai.com/og-image.png",
          "description": "Software de gestión administrativa para autónomos de reformas. Combina IA y acompañamiento humano para reducir hasta 30 horas mensuales de papeleo. Presupuestos, facturas, IVA y Verifactu sin aprender tecnología.",
          "featureList": [
            "Presupuestos y facturas numeradas",
            "IVA e IRPF calculados",
            "Listo para Verifactu",
            "Lectura automática de facturas de proveedores",
            "Control de rentabilidad por obra"
          ],
          "publisher": { "@id": "https://www.konquerai.com/#organization" },
          "author": { "@id": "https://www.konquerai.com/#organization" },
          "offers": {
            "@type": "Offer",
            "url": "https://www.konquerai.com/#pricing",
            "category": "Beta Fundadores",
            "price": "97",
            "priceCurrency": "EUR",
            "priceValidUntil": "2026-12-31",
            "availability": "https://schema.org/InStock",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "97",
              "priceCurrency": "EUR",
              "referenceQuantity": {
                "@type": "QuantitativeValue",
                "value": 1,
                "unitCode": "MON"
              }
            }
          }
        }
      ]
    })} />
  </head>
  <body class="bg-white text-ink antialiased">
    <!-- Sentinel para condensar la navbar al hacer scroll (sin listener de scroll) -->
    <div id="nav-sentinel" aria-hidden="true"></div>
    <div class="announce">
      <p>Plazas <strong>Beta Fundadores</strong> limitadas este mes · Puesta en marcha guiada paso a paso, en 15 minutos</p>
    </div>
    <slot />

    <!-- Chatbot "Tu consultor de Obra" + informe -->
    <Chatbot />
    <Report />

    <!-- IntersectionObserver fallback for scroll animations (Firefox) -->
    <script>
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reducedMotion && !CSS.supports('(animation-timeline: view()) and (animation-range: entry)')) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      }
    </script>

    <!-- Microinteracciones: spotlight en tarjetas + botones magnéticos -->
    <script>
      const rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Spotlight: la luz sigue al cursor sobre las tarjetas
      document.querySelectorAll<HTMLElement>('.pilar-card, .oferta-card, .card-spotlight').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', (e.clientX - r.left) + 'px');
          card.style.setProperty('--my', (e.clientY - r.top) + 'px');
        });
      });

      // Botones magnéticos (solo con ratón y sin reduced-motion)
      if (!rm && window.matchMedia('(hover: hover)').matches) {
        document.querySelectorAll<HTMLElement>('.btn-primary, .btn-white').forEach((btn) => {
          btn.addEventListener('mousemove', (e) => {
            const r = btn.getBoundingClientRect();
            const mx = e.clientX - r.left - r.width / 2;
            const my = e.clientY - r.top - r.height / 2;
            btn.style.transform = 'translate(' + (mx * 0.18) + 'px,' + (my * 0.28) + 'px)';
          });
          btn.addEventListener('mouseleave', () => { btn.style.transform = ''; });
        });
      }
    </script>

    <!-- Contadores animados (cuentan al entrar en viewport; respeta reduced-motion) -->
    <script>
      const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
      if (counters.length) {
        const reduceCounters = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const animateCounter = (el: HTMLElement) => {
          const target = parseFloat(el.dataset.counter ?? '0');
          const suffix = el.dataset.suffix ?? '';
          const prefix = el.dataset.prefix ?? '';
          if (reduceCounters) { el.textContent = prefix + target + suffix; return; }
          const duration = 1400;
          const start = performance.now();
          const frame = (now: number) => {
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = prefix + Math.floor(target * eased) + suffix;
            if (p < 1) requestAnimationFrame(frame);
            else el.textContent = prefix + target + suffix;
          };
          requestAnimationFrame(frame);
        };
        if (!('IntersectionObserver' in window)) {
          counters.forEach(animateCounter);
        } else {
          const cObs = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                animateCounter(entry.target as HTMLElement);
                cObs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.4 });
          counters.forEach((c) => cObs.observe(c));
        }
      }
    </script>

    <!-- Navbar flotante: se condensa al salir del top (sin listener de scroll) -->
    <script>
      const headerEl = document.getElementById('header');
      const sentinel = document.getElementById('nav-sentinel');
      if (headerEl && sentinel) {
        const navObs = new IntersectionObserver(([entry]) => {
          headerEl.classList.toggle('is-scrolled', !entry.isIntersecting);
        }, { threshold: 0 });
        navObs.observe(sentinel);
      }
    </script>

    <style>
      #nav-sentinel {
        position: absolute;
        top: 0;
        left: 0;
        width: 1px;
        height: 56px;
        pointer-events: none;
      }
      .announce {
        background: var(--color-ink);
        color: #fff;
        text-align: center;
        padding: 0.5rem 1rem;
        font-size: 0.8125rem;
        letter-spacing: 0.01em;
      }
      .announce strong { color: var(--color-teal); font-weight: 600; }
    </style>
  </body>
</html>
