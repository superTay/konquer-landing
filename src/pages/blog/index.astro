---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Solo posts publicados: la automatización de publicación cambia
// `status: draft` → `status: published` en el frontmatter (3/semana).
const posts = (await getCollection("blog", (p) => p.data.status === "published")).sort(
  (a, b) => {
    const byDate = b.data.date.valueOf() - a.data.date.valueOf();
    if (byDate !== 0) return byDate;
    return (a.data.plan_row ?? 0) - (b.data.plan_row ?? 0);
  },
);

const fechaLarga = new Intl.DateTimeFormat("es-ES", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Base
  title="Blog · KonquerAI — Guías para autónomos de reformas"
  description="Guías claras sobre Verifactu, facturas, IVA, presupuestos y rentabilidad para autónomos de reformas. Sin tecnicismos, oficio por oficio."
  ogTitle="Blog de KonquerAI — Guías para autónomos de reformas"
  ogDescription="Verifactu, facturas, IVA, presupuestos y rentabilidad, explicados claros y oficio por oficio."
  noindex={posts.length === 0}
>
  <Header />
  <main>
    <section class="blog-hero">
      <div class="container-narrow">
        <p class="text-eyebrow blog-eyebrow">Blog</p>
        <h1>Guías para llevar tu negocio de reformas al día</h1>
        <p class="blog-sub">
          Verifactu, facturas, IVA, presupuestos y lo que ganas en cada obra.
          Explicado claro, sin tecnicismos y oficio por oficio.
        </p>
      </div>
    </section>

    <section class="section-padding bg-mist">
      <div class="container-narrow">
        {posts.length === 0 && (
          <div class="blog-empty">
            <p class="blog-empty-title">Las primeras guías están al caer</p>
            <p>
              Estamos preparando guías sobre Verifactu, facturas, IVA y cómo saber
              qué obra te da dinero. Publicaremos varias cada semana.
            </p>
            <a href="/" class="btn btn-secondary">Volver a la portada</a>
          </div>
        )}
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card card-spotlight">
              <a href={`/blog/${post.data.slug}`} class="blog-card-link">
                <div class="blog-card-img">
                  <Image
                    src={post.data.imagen}
                    alt={post.data.imagen_alt}
                    widths={[400, 640, 800]}
                    sizes="(min-width: 1024px) 380px, (min-width: 640px) 45vw, 92vw"
                    loading="lazy"
                    format="webp"
                  />
                </div>
                <div class="blog-card-body">
                  <time datetime={post.data.date.toISOString().slice(0, 10)}>
                    {fechaLarga.format(post.data.date)}
                  </time>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.meta_description}</p>
                  <span class="blog-card-more">Leer la guía →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "@id": "https://www.konquerai.com/blog/#blog",
      "url": "https://www.konquerai.com/blog/",
      "name": "Blog de KonquerAI",
      "description": "Guías sobre Verifactu, facturación, IVA y gestión para autónomos de reformas.",
      "inLanguage": "es-ES",
      "publisher": { "@id": "https://www.konquerai.com/#organization" }
    })} />
  </Fragment>
</Base>

<style>
  .blog-hero {
    padding-block: 3.5rem 3rem;
  }
  @media (min-width: 768px) {
    .blog-hero { padding-block: 5rem 4rem; }
  }
  .blog-eyebrow { color: var(--color-teal-dark); margin-bottom: 0.75rem; }
  .blog-hero h1 { max-width: 40ch; }
  .blog-sub {
    margin-top: 1rem;
    max-width: 58ch;
    color: var(--color-slate);
    font-size: 1.0625rem;
  }

  .blog-empty {
    max-width: 34rem;
    margin-inline: auto;
    text-align: center;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    color: var(--color-slate);
  }
  .blog-empty-title {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; }
  }

  .blog-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .blog-card-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-mist);
  }
  .blog-card-img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .blog-card:hover .blog-card-img :global(img) {
    transform: scale(1.04);
  }
  .blog-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem 1.375rem 1.5rem;
    flex: 1;
  }
  .blog-card-body time {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-teal-dark);
    letter-spacing: 0.02em;
  }
  .blog-card-body h2 {
    font-size: 1.1875rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0;
  }
  .blog-card-body p {
    color: var(--color-slate);
    font-size: 0.9375rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-more {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-teal-dark);
  }
</style>
