---
import { getCollection, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  // Solo se generan páginas de los posts publicados (status: published)
  const posts = await getCollection("blog", (p) => p.data.status === "published");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// JSON-LD del propio post: viene como bloque ```json al final del markdown.
// El plugin remark lo quita del cuerpo visible; aquí lo extraemos del
// markdown crudo para inyectarlo en el <head>.
let postJsonLd: string | null = null;
const jsonBlock = post.body?.match(/```json\s*([\s\S]*?)```/);
if (jsonBlock) {
  try {
    postJsonLd = JSON.stringify(JSON.parse(jsonBlock[1]));
  } catch {
    postJsonLd = null; // JSON inválido: mejor no inyectar nada que romper el head
  }
}

// Imagen para Open Graph (versión optimizada y con URL absoluta)
const ogImg = await getImage({
  src: post.data.imagen,
  width: 1200,
  format: "jpg",
});
const ogImageUrl = new URL(ogImg.src, Astro.site).href;

const canonicalUrl = new URL(`/blog/${post.data.slug}/`, Astro.site).href;
const fechaISO = post.data.date.toISOString().slice(0, 10);
const fechaLarga = new Intl.DateTimeFormat("es-ES", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(post.data.date);

// Schema BlogPosting complementario al JSON-LD propio del post (FAQ/HowTo)
const blogPostingLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: post.data.title,
  description: post.data.meta_description,
  image: ogImageUrl,
  datePublished: fechaISO,
  dateModified: fechaISO,
  inLanguage: "es-ES",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  author: { "@id": "https://www.konquerai.com/#organization" },
  publisher: { "@id": "https://www.konquerai.com/#organization" },
  isPartOf: { "@id": "https://www.konquerai.com/blog/#blog" },
});
---

<Base
  title={`${post.data.title} · KonquerAI`}
  description={post.data.meta_description}
  ogTitle={post.data.title}
  ogDescription={post.data.meta_description}
  ogImage={ogImageUrl}
  ogImageAlt={post.data.imagen_alt}
  ogType="article"
>
  <Header />
  <main>
    <article class="post">
      <header class="post-header">
        <div class="container-narrow post-container">
          <nav class="post-breadcrumb" aria-label="Miga de pan">
            <a href="/blog">← Volver al blog</a>
          </nav>
          <h1>{post.data.title}</h1>
          <p class="post-meta">
            <time datetime={fechaISO}>{fechaLarga}</time>
          </p>
        </div>
        <div class="container-narrow post-container">
          <figure class="post-hero">
            <Image
              src={post.data.imagen}
              alt={post.data.imagen_alt}
              widths={[640, 960, 1400]}
              sizes="(min-width: 900px) 820px, 94vw"
              loading="eager"
              fetchpriority="high"
              format="webp"
            />
          </figure>
        </div>
      </header>

      <div class="container-narrow post-container">
        <div class="post-body">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <Footer />

  <Fragment slot="head">
    <script type="application/ld+json" set:html={blogPostingLd} />
    {postJsonLd && <script type="application/ld+json" set:html={postJsonLd} />}
  </Fragment>
</Base>

<style>
  .post-container {
    max-width: 872px; /* 820px de contenido + padding lateral */
  }

  .post-header {
    padding-top: 2.5rem;
  }
  .post-breadcrumb {
    margin-bottom: 1.5rem;
  }
  .post-breadcrumb a {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-teal-dark);
  }
  .post-breadcrumb a:hover {
    color: var(--color-teal);
  }
  .post-header h1 {
    max-width: 24ch;
    font-size: 2rem;
  }
  @media (min-width: 768px) {
    .post-header h1 { font-size: 2.5rem; }
  }
  .post-meta {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-teal-dark);
  }
  .post-hero {
    margin-top: 2rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .post-hero :global(img) {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* ── Cuerpo del artículo (markdown renderizado) ── */
  .post-body {
    padding-block: 2.5rem 4rem;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink);
  }

  .post-body :global(h2) {
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  @media (min-width: 768px) {
    .post-body :global(h2) { font-size: 1.75rem; }
  }
  .post-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-body :global(p) {
    margin-bottom: 1.125rem;
  }
  .post-body :global(a) {
    color: var(--color-teal-dark);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(0, 155, 137, 0.35);
    text-underline-offset: 3px;
  }
  .post-body :global(a:hover) {
    color: var(--color-teal);
  }
  .post-body :global(strong) {
    font-weight: 700;
  }

  /* TL;DR: primer blockquote del post, destacado en teal */
  .post-body :global(blockquote) {
    margin: 1.75rem 0;
    padding: 1.125rem 1.375rem;
    background: var(--color-mist);
    border-left: 4px solid var(--color-orange);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: 1rem;
  }
  .post-body :global(blockquote:first-child) {
    background: var(--color-teal-light);
    border-left-color: var(--color-teal);
    font-size: 1.0625rem;
  }
  .post-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.25rem 1.375rem;
  }
  .post-body :global(li) {
    margin-bottom: 0.4375rem;
  }
  .post-body :global(li::marker) {
    color: var(--color-teal-dark);
  }
  .post-body :global(input[type="checkbox"]) {
    margin-right: 0.5rem;
    accent-color: var(--color-teal);
  }
  .post-body :global(ul:has(input[type="checkbox"])) {
    list-style: none;
    margin-left: 0.25rem;
  }

  /* Tablas (comparativas de fechas, oficios, IVA…) */
  .post-body :global(table) {
    display: block;
    overflow-x: auto;
    width: 100%;
    margin: 1.75rem 0;
    border-collapse: collapse;
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.625rem 0.875rem;
    text-align: left;
    min-width: 8rem;
  }
  .post-body :global(th) {
    background: var(--color-mist);
    font-family: var(--font-heading);
    font-weight: 600;
    white-space: nowrap;
  }
  .post-body :global(tbody tr:nth-child(even)) {
    background: rgba(246, 248, 249, 0.6);
  }

  .post-body :global(hr) {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid var(--color-border);
  }

  .post-body :global(code) {
    font-size: 0.9em;
    background: var(--color-mist);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }
</style>
